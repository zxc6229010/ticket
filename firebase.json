{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "site",
    "rewrites": [
      {
        "source": "/api/createUserWithEmail",
        "function": "createUserWithEmailHttp"
      }
    ]
  }
}